---
import Layout from '../layouts/Layout.astro';
import Welcome from '../components/Welcome.astro';
import AboutMe from '../components/AboutMe.astro';
import Skills from '../components/Skills.astro';
import Projects from '../components/Projects.astro';
import SiteNav from '../components/SiteNav.astro';
import CursorTrail from '../components/CursorTrail.astro';
---
<Layout>
	<main class="flex flex-col items-center justify-start px-4 sm:px-6 lg:px-32 pt-8 sm:pt-12 pb-16">
		<SiteNav />

		<div class="mt-16 sm:mt-20 w-full flex justify-center">
			<Welcome />
		</div>

		<div id="about" class="w-full mt-16 sm:mt-20">
			<AboutMe />
		</div>

		<div id="skills" class="w-full mt-16 sm:mt-20">
			<Skills />
		</div>

		<div id="projects" class="w-full mt-16 sm:mt-20">
			<Projects />
		</div>
	</main>

	<CursorTrail />
</Layout>
