</div>

<style>
  .flash-active .flash-overlay {
    animation: aboutFlash 1.8s ease-out;
  }

  @keyframes aboutFlash {
    0% {
      opacity: 0;
      transform: scale(0.98);
    }
    30% {
      opacity: 0.24;
      transform: scale(1.02);
    }
    100% {
      opacity: 0;
      transform: scale(1);
    }
  }

  .shadow-lg {
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1), 0 2px 4px rgba(0, 0, 0, 0.06);
  }

  .hover\:shadow-python:hover {
    filter: drop-shadow(0 0 10px rgba(255, 222, 89, 0.6));
  }
  .hover\:shadow-django:hover {
    filter: drop-shadow(0 0 10px rgba(193, 255, 114, 0.6));
  }
  .hover\:shadow-selenium:hover {
    filter: drop-shadow(0 0 10px rgba(255, 255, 255, 0.6));
  }
  .hover\:shadow-java:hover {
    filter: drop-shadow(0 0 10px rgba(255, 0, 0, 0.6));
  }

  .text-shadow-python {
    text-shadow: 0 0 10px rgba(255, 222, 89, 0.6);
  }
  .text-shadow-django {
    text-shadow: 0 0 10px rgba(193, 255, 114, 0.6);
  }
  .text-shadow-selenium {
    text-shadow: 0 0 10px rgba(255, 255, 255, 0.6);
  }
  .text-shadow-java {
    text-shadow: 0 0 10px rgba(255, 0, 0, 0.6);
  }

  @keyframes fadeInUp {
    0% {
      opacity: 0;
      transform: translateY(30px) scale(0.95);
    }
    60% {
      opacity: 1;
      transform: translateY(-10px) scale(1.02);
    }
    100% {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
  .animate-fadeInUp {
    animation: fadeInUp 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  }

  @media (prefers-reduced-motion: reduce) {
    .animate-fadeInUp {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }

  .no-scrollbar {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }

  :global(html) {
    scrollbar-gutter: stable;
  }
</style>

<script type="module" is:inline define:vars={{ galleries }}>
  const cards = document.querySelectorAll('.card');
  const modal = document.getElementById('project-gallery-modal');
  
  // MOVER EL MODAL AL BODY PARA EVITAR PROBLEMAS DE POSICIONAMIENTO CON ANIMACIONES ANCESTROS
  if (modal && modal.parentElement !== document.body) {
    document.body.appendChild(modal);
  }

  const modalPanel = modal?.querySelector('[data-modal-panel]');
  const modalBackdrop = modal?.querySelector('[data-modal-backdrop]');
  const titleEl = document.getElementById('gallery-title');
  const repoEl = document.getElementById('gallery-repo');
  const repoIconEl = document.getElementById('gallery-repo-icon');
  const previewEl = document.getElementById('gallery-preview');
  const emptyEl = document.getElementById('gallery-empty');
  const thumbsEl = document.getElementById('gallery-thumbs');
  const closeTriggers = modal ? modal.querySelectorAll('[data-close]') : [];
  
  // PRECARGA DE IMÁGENES
  // Carga todas las imágenes de la galería en segundo plano cuando la página termina de cargar
  window.addEventListener('load', () => {
    // Retrasar precarga ligeramente para no interferir con la renderización inicial
    setTimeout(() => {
      Object.values(galleries).flat().forEach((src) => {
        if (typeof src === 'string') {
          const img = new Image();
          img.src = src;
        }
      });
    }, 1000);
  });

  const projectMeta = {
    equigrafo: {
      title: 'Equigrafo',
      repo: 'https://github.com/Matheuzk/Equigrafo',
      stack: ['Python', 'Django', 'Selenium', 'MySQL', 'JavaScript'],
      description: 'Automatiza la extracción de puntajes hípicos y estadísticas mediante Web Scraping y procesamiento en tiempo real.',
      features: ['Extracción de datos asíncrona', 'Panel administrativo', 'Reportes en PDF', 'Calculadora de clasificaciones'],
      installCmd: 'git clone https://github.com/Matheuzk/Equigrafo.git',
      accentColor: 'pink',
      checkIconColor: 'text-pink-400',
      installBgColor: 'bg-pink-500',
btnBg: 'bg-pink-100 hover:bg-pink-200 text-pink-600 border-pink-400/30 dark:bg-pink-500/20 dark:hover:bg-pink-500/30 dark:text-pink-300 dark:border-pink-500/30',
      iconColor: 'text-pink-600 group-hover:text-pink-500 dark:text-pink-400 dark:group-hover:text-pink-300',
      thumbHoverColor: 'hover:border-pink-400/50 dark:hover:border-pink-400/50',
      thumbFocusRing: 'focus:ring-pink-400/50 dark:focus:ring-pink-400/70',
      modalBorder: 'border-pink-300/40 dark:border-pink-500/40',
      modalShadow: 'shadow-pink-500/10 dark:shadow-pink-500/20',
      modalBg: 'bg-[#f6f4f0] dark:bg-[#3b3b3b]/98',
      badgeClass: 'text-pink-700 bg-pink-100 border border-pink-300/40 dark:text-pink-200 dark:bg-pink-500/10 dark:border-pink-500/20'
    },
    sportplus: {
      title: 'SportPlus',
      repo: 'https://github.com/Matheuzk/SportPlus',
      stack: ['Java', 'MySQL'],
      description: 'Sistema integral de Punto de Venta (POS) para tiendas con gestión avanzada de inventarios, clientes y proveedores.',
      features: ['Facturación de ventas', 'Alerta de bajo stock', 'Múltiples sucursales', 'Cierre de caja en un clic'], 
      installCmd: 'git clone https://github.com/Matheuzk/SportPlus.git',
      accentColor: 'cyan',
      checkIconColor: 'text-cyan-500 dark:text-cyan-400',
      installBgColor: 'bg-cyan-400 dark:bg-cyan-500',
      btnBg: 'bg-cyan-100 hover:bg-cyan-200 text-cyan-700 border-cyan-400/30 dark:bg-cyan-500/20 dark:hover:bg-cyan-500/30 dark:text-cyan-300 dark:border-cyan-500/30',
      iconColor: 'text-cyan-600 group-hover:text-cyan-500 dark:text-cyan-400 dark:group-hover:text-cyan-300',
      thumbHoverColor: 'hover:border-cyan-400/50 dark:hover:border-cyan-400/50',
      thumbFocusRing: 'focus:ring-cyan-300/60 dark:focus:ring-cyan-400/70',
      modalBorder: 'border-cyan-300/40 dark:border-cyan-500/40',
      modalShadow: 'shadow-cyan-500/10 dark:shadow-cyan-500/20',
      modalBg: 'bg-[#f6f4f0] dark:bg-[#0f1b2a]/95',
      badgeClass: 'text-cyan-800 bg-cyan-100 border border-cyan-300/40 dark:text-cyan-200 dark:bg-cyan-500/10 dark:border-cyan-500/20'
    },
  };

  const getScrollbarWidth = () => window.innerWidth - document.documentElement.clientWidth;

  const openModalAnimation = () => {
    if (!modal || !modalPanel || !modalBackdrop) return;

    modal.classList.remove('invisible', 'pointer-events-none');
    modal.classList.add('opacity-100');

    requestAnimationFrame(() => {
      modalBackdrop.classList.add('opacity-100');
      modalPanel.classList.remove('opacity-0');
      modalPanel.classList.add('opacity-100');
    });
  };

  const closeModalAnimation = () => {
    if (!modal || !modalPanel || !modalBackdrop) return;

    modalBackdrop.classList.remove('opacity-100');
    modalPanel.classList.remove('opacity-100');
    modalPanel.classList.add('opacity-0');
    modal.classList.remove('opacity-100');
    modal.classList.add('opacity-0');

    window.setTimeout(() => {
      modal.classList.add('invisible', 'pointer-events-none');
    }, 300);
  };

  const openModal = (projectKey) => {
    const meta = projectMeta[projectKey];
    const images = galleries[projectKey] ?? [];

    // Limpiar clases dinámicas del modal y aplicar colores del proyecto
    modalPanel.className = `relative flex flex-col z-10 w-full max-w-[98vw] h-[95vh] rounded-[10px] border border-slate-300 dark:border-white/10 ${meta.modalBg} shadow-2xl opacity-0 transition-opacity duration-300 ease-out sm:max-w-[1100px] lg:max-w-[1200px] mx-auto overflow-hidden ring-1 ring-inset ring-${meta.accentColor}-500/20`;

    // Cambiar color de la barra superior dependiendo del proyecto
    document.getElementById('gallery-window-header').className = `flex items-center justify-between bg-transparent px-3 py-2 shrink-0 select-none relative z-20`;

    document.getElementById('gallery-window-title').className = `absolute left-1/2 -translate-x-1/2 text-center text-xs font-mono text-slate-600 dark:text-gray-400 tracking-wide select-none`;
    document.getElementById('gallery-window-title').textContent = `${projectKey}.sh`;
    titleEl.textContent = meta.title;

    thumbsEl.innerHTML = '';

    if (meta.repo) {
      repoEl.href = meta.repo;
      repoEl.classList.remove('hidden');
    } else {
      repoEl.classList.add('hidden');
    }

    if (images.length > 0) {
      previewEl.classList.remove('hidden');
      emptyEl.classList.add('hidden');

      const setPreview = (src, alt) => {
        previewEl.src = src;
        previewEl.alt = alt;
      };

      setPreview(images[0], `${meta.title} - imagen principal`);

      thumbsEl.innerHTML = images
        .map(
          (src, index) => `
            <button
              type="button"
              class="group relative z-20 shrink-0 snap-center overflow-hidden rounded-xl border-2 border-transparent bg-slate-200/50 dark:bg-black/20 p-1 transition-all duration-300 hover:scale-[1.02] hover:-translate-y-1 ${meta.thumbHoverColor} focus:outline-none focus:ring-2 ${meta.thumbFocusRing} w-[100px] sm:w-[130px] mt-1"
              data-thumb-index="${index}"
              aria-label="Ver imagen ${index + 1} de ${meta.title}"
            >
              <img
                src="${src}"
                alt="${meta.title} miniatura ${index + 1}"
                loading="lazy"
                decoding="async"
                class="h-16 sm:h-[4.5rem] w-full rounded-lg object-cover transition-transform duration-500 group-hover:scale-110"
              />
            </button>
          `
        )
        .join('');

      thumbsEl.querySelectorAll('[data-thumb-index]').forEach((button) => {
        button.addEventListener('click', () => {
          const index = Number(button.getAttribute('data-thumb-index'));
          setPreview(images[index], `${meta.title} - imagen ${index + 1}`);
          button.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
        });
      });
    } else {
      previewEl.classList.add('hidden');
      emptyEl.classList.remove('hidden');
    }

    const scrollbarWidth = getScrollbarWidth();
    if (scrollbarWidth > 0) {
      document.body.style.paddingRight = `${scrollbarWidth}px`;
    }
    document.body.classList.add('overflow-hidden');
    openModalAnimation();
  };

  const closeModal = () => {
    document.body.classList.remove('overflow-hidden');
    document.body.style.paddingRight = '';
    closeModalAnimation();
  };

  cards.forEach((card) => {
    card.addEventListener('click', () => {
      const projectKey = card.getAttribute('data-open-gallery');
      if (projectKey) {
        openModal(projectKey);
      }
    });
  });

  closeTriggers.forEach((trigger) => {
    trigger.addEventListener('click', closeModal);
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && modal && !modal.classList.contains('hidden')) {
      closeModal();
    }
  });

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('animate-fadeInUp');
          observer.unobserve(entry.target);
        }
      });
    },
    {
      threshold: 0.18,
      rootMargin: '0px 0px -18% 0px',
    }
  );

  cards.forEach((card) => observer.observe(card));

  const projectsSection = document.querySelector('.projects-section');
  const projectParagraphs = document.querySelectorAll('.project-paragraph');
  
  const playProjectSequence = () => {
    projectParagraphs.forEach((paragraph, index) => {
      paragraph.classList.remove('flash-active');
      window.setTimeout(() => {
        paragraph.classList.add('flash-active');
        window.setTimeout(() => {
          paragraph.classList.remove('flash-active');
        }, 1800);
      }, index * 520);
    });
  };

  const projectObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          playProjectSequence();
          projectObserver.unobserve(entry.target);
        }
      });
    },
    {
      threshold: 0.25,
      rootMargin: '0px 0px -12% 0px',
    }
  );

  if (projectsSection) {
    projectObserver.observe(projectsSection);
  }
</script>