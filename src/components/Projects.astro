---
import { FaPython, FaJava, FaGithub } from 'react-icons/fa';
import { SiDjango, SiSelenium } from 'react-icons/si';
import { getImage } from 'astro:assets';

const getOptimizedImages = async (globMap: any) => {
  const entries = Object.entries(globMap).sort(([a], [b]) => a.localeCompare(b, 'es'));
  const optimized = await Promise.all(entries.map(async ([, image]) => {
    if (typeof image === 'string') {
      return image;
    }
    // Optimizar imagen para mejor nitidez en el visualizador
    const optImg = await getImage({ src: image as any, width: 1600, format: 'webp', quality: 95 });
    return optImg.src;
  }));
  return optimized.filter(Boolean);
};

const equigrafoImages = await getOptimizedImages(
  import.meta.glob('../assets/projects/equigrafo/*.{png,jpg,jpeg,webp,gif,svg}', { eager: true, import: 'default' })
);

const sportplusImages = await getOptimizedImages(
  import.meta.glob('../assets/projects/sportplus/*.{png,jpg,jpeg,webp,gif,svg}', { eager: true, import: 'default' })
);

const galleries = {
  equigrafo: equigrafoImages,
  sportplus: sportplusImages,
};

---

