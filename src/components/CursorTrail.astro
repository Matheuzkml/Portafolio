<script>
  document.addEventListener('mousemove', (e) => {
    const spore = document.createElement('span');
    const width = Math.random() * 8 + 4;
    const height = width * (Math.random() * 0.5 + 0.8);

    spore.style.position = 'absolute';
    spore.style.left = `${e.pageX - width / 2}px`;
    spore.style.top = `${e.pageY - height / 2}px`;
    spore.style.width = `${width}px`;
    spore.style.height = `${height}px`;
    
    // Verificar si el modo oscuro está activo
    const isDark = document.documentElement.classList.contains('dark');
    const trailColor = isDark ? 'rgba(255,248,220,0.7)' : 'rgba(48,48,48,0.5)';
    spore.style.background = `radial-gradient(circle, ${trailColor} 0%, transparent 70%)`;
    
    spore.style.borderRadius = '50%';
    spore.style.pointerEvents = 'none';
    spore.style.filter = 'blur(2px)';

    const deltaX = (Math.random() - 0.5) * 80;
    const deltaY = -(Math.random() * 60 + 20);
    const rotation = (Math.random() - 0.5) * 180;

    spore.animate(
      [
        { transform: 'translate(0,0) rotate(0deg) scale(1)', opacity: 1 },
        {
          transform: `translate(${deltaX}px, ${deltaY}px) rotate(${rotation}deg) scale(1.3)`,
          opacity: 0,
        },
      ],
      {
        duration: 2000,
        easing: 'ease-out',
        fill: 'forwards',
      }
    );

    document.body.appendChild(spore);
    setTimeout(() => spore.remove(), 2000);
  });
</script>