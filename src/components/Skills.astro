---

import { FaDatabase, FaJava, FaPython } from 'react-icons/fa';
import {
  SiAstro,
  SiBootstrap,
  SiCss,
  SiDjango,
  SiHtml5,
  SiJavascript,
  SiMysql,
  SiSelenium,
  SiVuedotjs,
} from 'react-icons/si';

const categories = [
  {
    titleEs: 'Frontend y UI',
    titleEn: 'Frontend & UI',
    colSpan: 'col-span-2 lg:col-span-2 md:col-span-2',
    accent: 'dark:text-[#ffde59]',
    border: 'dark:border-[#ffde59]/25',
    glow: 'dark:from-[#ffde59]/10 dark:to-transparent',
    items: [
      { label: 'Astro', Icon: SiAstro, color: 'text-[#ff5d9e]' },
      { label: 'Vue', Icon: SiVuedotjs, color: 'text-[#42d392]' },
      { label: 'JavaScript', Icon: SiJavascript, color: 'text-[#f7df1e]' },
      { label: 'HTML', Icon: SiHtml5, color: 'text-[#ff7a45]' },
      { label: 'CSS', Icon: SiCss, color: 'text-[#4cc9f0]' },
      { label: 'Bootstrap', Icon: SiBootstrap, color: 'text-[#9b59ff]' },
    ],
  },
  {
    titleEs: 'Backend',
    titleEn: 'Backend',
    accent: 'dark:text-[#cb6ce6]',
    border: 'dark:border-[#cb6ce6]/25',
    glow: 'dark:from-[#cb6ce6]/10 dark:to-transparent',
    items: [
      { label: 'Python', Icon: FaPython, color: 'text-[#ffde59]' },
      { label: 'Java', Icon: FaJava, color: 'text-[#ff5757]' },
      { label: 'Django', Icon: SiDjango, color: 'text-[#c1ff72]' },
    ],
  },
  {
    titleEs: 'Datos',
    titleEn: 'Data',
    accent: 'dark:text-[#5ce1e6]',
    border: 'dark:border-[#5ce1e6]/25',
    glow: 'dark:from-[#5ce1e6]/10 dark:to-transparent',
    items: [
      { label: 'SQL', Icon: FaDatabase, color: 'text-[#7dd3fc]' },
      { label: 'MySQL', Icon: SiMysql, color: 'text-[#f59e0b]' },
      { label: 'Selenium', Icon: SiSelenium, color: 'text-white' },
    ],
  },
];
---

<section id="skills" class="skills-section container mx-auto px-8 mt-24" style="scroll-margin-top: 96px;">
  <div>
    <h2 class="mb-4 text-3xl font-semibold text-[#ffde59] md:text-4xl">
      <span class="lang-es">Tecnologías y habilidades</span><span class="lang-en">Technologies and skills</span>
    </h2>
    <div class="w-full sm:w-3/4 md:w-1/2 mt-8 mb-4">
      <p class="skill-paragraph relative group text-lg sm:text-xl leading-relaxed text-slate-700 dark:text-slate-300 transition-colors duration-300">
        <span class="lang-es">Las herramientas que uso a <span class="text-[#5ce1e6]">diario</span>.</span>
        <span class="lang-en">The tools I use on a <span class="text-[#5ce1e6]">daily</span> basis.</span>
        <span class="flash-overlay absolute inset-0 rounded-lg bg-[#ffde59] opacity-0 blur-lg transition duration-500 group-hover:opacity-20"></span>
      </p>
    </div>
  </div>

  <div class="mt-12 grid gap-6 grid-cols-2 md:grid-cols-2 lg:grid-cols-4 w-full">
    {categories.map((category) => (
      <article class={`skill-card ${category.colSpan || ''} group relative overflow-hidden rounded-3xl border border-slate-300 dark:border-white/10 ${category.border} bg-white/60 dark:bg-white/10 shadow-sm dark:shadow-none p-4 sm:p-6 backdrop-blur-sm opacity-0 transition-colors duration-300`}>
        <div class={`absolute inset-0 bg-gradient-to-br ${category.glow} opacity-0 dark:opacity-80 transition-opacity duration-300`}></div>

        <div class="relative z-10">
          <h3 class={`mb-4 sm:mb-5 text-xl sm:text-2xl font-semibold text-slate-800 ${category.accent} transition-colors duration-300 md:text-3xl`}>
            <span class="lang-es">{category.titleEs}</span><span class="lang-en">{category.titleEn}</span>
          </h3>

          <div class="flex flex-wrap gap-2 md:gap-2.5 w-full">
            {category.items.map((item) => (
              <span class="skill-chip inline-flex w-fit items-center justify-center gap-1.5 sm:gap-2 rounded-[1rem] border border-slate-200 dark:border-white/10 bg-white dark:bg-[#0f172a]/70 shadow-sm dark:shadow-none px-2.5 sm:px-3 py-1.5 text-[11px] sm:text-xs md:text-[13px] text-slate-700 dark:text-slate-100 transition-all duration-300 group-hover:-translate-y-1 group-hover:border-slate-400 dark:group-hover:border-white/20">
                <item.Icon className={`${item.color} text-sm sm:text-base md:text-[1.1rem] shrink-0`} />
                <span class="truncate whitespace-nowrap">{item.label}</span>
              </span>
            ))}
          </div>
        </div>
      </article>
    ))}
  </div>
</section>

<script type="module" is:inline>
  const section = document.querySelector('.skills-section');
  const cards = document.querySelectorAll('.skill-card');
  const paragraphs = document.querySelectorAll('.skill-paragraph');

  const playSequence = () => {
    paragraphs.forEach((paragraph, index) => {
      paragraph.classList.remove('flash-active');
      window.setTimeout(() => {
        paragraph.classList.add('flash-active');
        window.setTimeout(() => {
          paragraph.classList.remove('flash-active');
        }, 1800);
      }, index * 520);
    });
  };

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          playSequence();

          const visibleCards = Array.from(cards);

          visibleCards.forEach((card, index) => {
            window.setTimeout(() => {
              card.classList.add('animate-skill-card');
            }, index * 180);
          });

          observer.unobserve(entry.target);
        }
      });
    },
    {
      threshold: 0.35,
      rootMargin: '0px 0px -10% 0px',
    }
  );

  if (section) {
    observer.observe(section);
  }
</script>

<style>
  .flash-active .flash-overlay {
    animation: aboutFlash 1.8s ease-out;
  }

  @keyframes aboutFlash {
    0% {
      opacity: 0;
      transform: scale(0.98);
    }
    30% {
      opacity: 0.24;
      transform: scale(1.02);
    }
    100% {
      opacity: 0;
      transform: scale(1);
    }
  }

  @keyframes skillFlash {
    0%,
    100% {
      opacity: 0;
      transform: scale(0.98);
    }
    30% {
      opacity: 0.18;
      transform: scale(1.02);
    }
  }

  @keyframes skillCardIn {
    0% {
      opacity: 0;
      transform: translateY(24px) scale(0.98);
    }
    100% {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .animate-skill-card {
    animation: skillCardIn 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  }
</style>