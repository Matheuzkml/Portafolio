</div>

<script type="module" is:inline>
  const section = document.querySelector('.about-section');
  const paragraphs = document.querySelectorAll('.about-paragraph');

  const playSequence = () => {
    paragraphs.forEach((paragraph, index) => {
      paragraph.classList.remove('flash-active');

      window.setTimeout(() => {
        paragraph.classList.add('flash-active');

        window.setTimeout(() => {
          paragraph.classList.remove('flash-active');
        }, 1800);
      }, index * 520);
    });
  };

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          playSequence();
        }
      });
    },
    {
      threshold: 0.45,
      rootMargin: '0px 0px -12% 0px',
    }
  );

  if (section) {
    observer.observe(section);
  }
</script>

<style>
  .flash-active .flash-overlay {
    animation: aboutFlash 1.8s ease-out;
  }

  @keyframes aboutFlash {
    0% {
      opacity: 0;
      transform: scale(0.98);
    }
    30% {
      opacity: 0.24;
      transform: scale(1.02);
    }
    100% {
      opacity: 0;
      transform: scale(1);
    }
  }
</style>