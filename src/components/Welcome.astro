---
import { FaGithub, FaLinkedin } from 'react-icons/fa'
---
<div class="container mx-auto flex w-full flex-col items-center justify-between px-4 sm:px-6 md:flex-row md:px-8">
  <div class="w-full md:w-3/4">
    <p class="mb-2 text-lg text-[#9ca3af] sm:text-xl md:text-2xl">Matheuzkm</p>

    <h1 class="mb-4 text-4xl font-semibold leading-tight tracking-tight sm:text-5xl md:text-6xl">
      <span class="lang-es"><span class="text-[#cb6ce6]">Aprendiendo</span> y Creando<br />Soluciones<span class="text-[#cb6ce6]">.</span></span>
      <span class="lang-en"><span class="text-[#cb6ce6]">Learning</span> & Creating<br />Solutions<span class="text-[#cb6ce6]">.</span></span>
    </h1>
    <div class="mb-6 flex items-center space-x-4">
      <a href="https://github.com/Matheuzk" 
         target="_blank" 
         class="text-pink-500 transition-colors duration-300 ease-in-out hover:text-pink-400 hover:shadow-github">
        <FaGithub size={32} />
      </a>
      <a href="https://www.linkedin.com/in/mateo-antonio-valencia-rojas-409454326/" 
         target="_blank" 
         class="text-cyan-400 transition-colors duration-300 ease-in-out hover:text-cyan-300 hover:shadow-linkedin mr-3">
        <FaLinkedin size={32} />
      </a>
      
      <!-- Botón de CV (Super Minimalista) -->
      <a href="/CV.pdf" 
         target="_blank"
         class="text-2xl font-bold tracking-widest text-[#9ca3af] hover:text-[#fbcfe8] hover:drop-shadow-[0_0_8px_rgba(251,207,232,0.8)] transition-all duration-300"
         download>
         CV
      </a>
    </div>
    <p class="mb-2 text-base sm:text-lg md:text-xl">
      <span style="color: #ffde59;">&#123;</span>
      <span class="text-slate-800 dark:text-slate-100"> Mateo valencia </span>
      <span style="color: #ff66c4;">&#125;</span>
    </p>
    <p class="text-lg text-gray-500 sm:text-xl md:text-2xl">Frontend Designer / Backend Developer</p>
  </div>
  <div class="mb-8 flex justify-center md:mb-0 md:ml-auto md:w-1/4">
    <img
      src="/assets/perfil.png"
      alt="Avatar"
      class="h-40 w-40 rounded-2xl object-cover sm:h-56 sm:w-56 md:h-64 md:w-64"
    />
  </div>
</div>

<style>
  .hover\:shadow-github:hover {
    filter: drop-shadow(0 0 10px rgba(236, 72, 153, 0.6));
  }
  .hover\:shadow-linkedin:hover {
    filter: drop-shadow(0 0 10px rgba(34, 211, 238, 0.6));
  }
</style>