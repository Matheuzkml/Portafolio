---
import { FaGithub, FaLinkedin } from 'react-icons/fa'
---
<div class="container mx-auto flex w-full flex-col items-center justify-between px-4 sm:px-6 md:flex-row md:px-8">
  <div class="w-full md:w-3/4">
    <p class="mb-2 text-lg text-[#9ca3af] sm:text-xl md:text-2xl">Matheuzkm</p>

    <h1 class="mb-4 text-4xl font-semibold leading-tight tracking-tight sm:text-5xl md:text-6xl">
      <span class="lang-es"><span class="text-[#cb6ce6]">Aprendiendo</span> y Creando<br />Soluciones<span class="text-[#cb6ce6]">.</span></span>
      <span class="lang-en"><span class="text-[#cb6ce6]">Learning</span> & Creating<br />Solutions<span class="text-[#cb6ce6]">.</span></span>
    </h1>
    <div class="mb-6 flex items-center space-x-4">
      <a href="https://github.com/Matheuzk" 
         target="_blank" 
         class="text-pink-500 transition-colors duration-300 ease-in-out hover:text-pink-400 hover:shadow-github">
        <FaGithub size={32} />
      </a>
      <a href="https://www.linkedin.com/in/mateo-antonio-valencia-rojas-409454326/" 
         target="_blank" 
         class="text-cyan-400 transition-colors duration-300 ease-in-out hover:text-cyan-300 hover:shadow-linkedin mr-3">
        <FaLinkedin size={32} />
      </a>
      
      <!-- Botón de CV (Super Minimalista) -->
      <a href="/CV.pdf" 
         target="_blank"
         class="text-2xl font-bold tracking-widest text-[#9ca3af] hover:text-[#fbcfe8] hover:drop-shadow-[0_0_8px_rgba(251,207,232,0.8)] transition-all duration-300"
         download>
         CV
      </a>
    </div>
    <p class="mb-2 text-base sm:text-lg md:text-xl">
      <span style="color: #ffde59;">&#123;</span>
      <span class="text-slate-800 dark:text-slate-100"> Mateo valencia </span>
      <span style="color: #ff66c4;">&#125;</span>
    </p>
    <p class="text-lg text-gray-500 sm:text-xl md:text-2xl">Frontend Designer / Backend Developer</p>
  </div>
  <div class="mb-8 flex flex-col items-center justify-center md:mb-0 md:ml-auto md:w-1/4 gap-6">
    <img
      src="/assets/perfil.png"
      alt="Avatar"
      class="h-40 w-40 rounded-2xl object-cover sm:h-56 sm:w-56 md:h-64 md:w-64"
    />
    
    <!-- Reproductor de música Custom Elegante -->
    <div class="group relative w-full max-w-[260px] bg-white/40 dark:bg-[#1a1a1a]/80 p-3 rounded-2xl border border-slate-200/50 dark:border-white/10 shadow-[0_8px_30px_rgb(0,0,0,0.04)] dark:shadow-[0_8px_30px_rgb(0,0,0,0.2)] backdrop-blur-md transition-all duration-300 hover:border-pink-400/50 flex items-center gap-3">
      
      <!-- Audio Oculto -->
      <audio id="custom-audio" src="/assets/Daniel, Me Estás Matando - Arráncame.flac" preload="metadata"></audio>

      <!-- Miniatura / Icono Animado / Cover del Álbum -->
      <div class="relative w-12 h-12 flex-shrink-0 rounded-xl bg-slate-200 dark:bg-slate-700 flex items-center justify-center shadow-inner overflow-hidden">
        <!-- Portada del Álbum (inyectado por JS) -->
        <img id="music-cover" class="absolute inset-0 w-full h-full object-cover hidden transition-opacity duration-300" alt="Cover" />
        
        <!-- Icono Alternativo si no hay foto -->
        <svg id="music-icon" class="w-6 h-6 text-slate-400 dark:text-slate-500 drop-shadow-sm" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"></path></svg>
        
        <!-- Ondas cuando reproduce -->
        <div id="audio-waves" class="absolute inset-0 flex items-center justify-center gap-[3px] bg-black/40 backdrop-blur-[1.5px] opacity-0 transition-opacity duration-300 z-10">
          <span class="w-[3px] h-3 bg-white rounded-full animate-musicWave" style="animation-delay: 0.0s"></span>
          <span class="w-[3px] h-5 bg-white rounded-full animate-musicWave" style="animation-delay: 0.2s"></span>
          <span class="w-[3px] h-3 bg-white rounded-full animate-musicWave" style="animation-delay: 0.4s"></span>
        </div>
      </div>

      <!-- Información y Progreso -->
      <div class="flex-1 min-w-0 pt-0.5">
        <h4 id="music-title" class="text-sm font-bold text-slate-800 dark:text-white truncate tracking-tight">Cargando...</h4>
        <p id="music-artist" class="text-[10px] uppercase font-bold tracking-wider text-slate-500 dark:text-slate-400 truncate mb-1.5"><span class="lang-es">MI ROLA FAVORITA</span><span class="lang-en hidden">FAV TRACK</span></p>
        
        <!-- Barra de Progreso Custom -->
        <div id="progress-container" class="w-full h-1.5 bg-slate-200 dark:bg-slate-700/60 rounded-full cursor-pointer relative overflow-hidden group/progress">
          <div id="progress-bar" class="absolute left-0 top-0 h-full bg-gradient-to-r from-pink-500 to-cyan-400 w-0 pointer-events-none transition-[width] duration-[50ms] ease-linear"></div>
        </div>
      </div>

      <!-- Botón Play/Pause -->
      <button id="play-pause-btn" class="w-10 h-10 flex-shrink-0 flex items-center justify-center rounded-full bg-slate-100 dark:bg-white/10 text-slate-800 dark:text-white hover:bg-pink-50 hover:text-pink-600 dark:hover:bg-pink-500/20 dark:hover:text-pink-300 shadow-sm transition-all focus:outline-none focus:ring-2 focus:ring-pink-400/50 active:scale-95">
        <svg id="icon-play" class="w-4 h-4 ml-1" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
        <svg id="icon-pause" class="w-4 h-4 hidden" fill="currentColor" viewBox="0 0 24 24"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
      </button>

    </div>
  </div>
</div>

<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/jsmediatags/3.9.5/jsmediatags.min.js"></script>
<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const audio = document.getElementById('custom-audio');
    const playBtn = document.getElementById('play-pause-btn');
    const iconPlay = document.getElementById('icon-play');
    const iconPause = document.getElementById('icon-pause');
    const progressBar = document.getElementById('progress-bar');
    const progressContainer = document.getElementById('progress-container');
    const audioWaves = document.getElementById('audio-waves');
    
    const titleEl = document.getElementById('music-title');
    const artistEl = document.getElementById('music-artist');
    const coverEl = document.getElementById('music-cover');
    const iconEl = document.getElementById('music-icon');
    
    if(!audio || !playBtn) return;

    if (window.jsmediatags) {
      window.jsmediatags.read(audio.src, {
        onSuccess: function(tag) {
          const tags = tag.tags;
          
          if (tags.title) titleEl.textContent = tags.title;
          else titleEl.textContent = "Arráncame";

          if (tags.artist) artistEl.textContent = tags.artist;
          else artistEl.innerHTML = '<span class="lang-es">DANIEL, ME ESTÁS MATANDO</span><span class="lang-en hidden">DANIEL, ME ESTÁS MATANDO</span>';
          
          if (tags.picture) {
            const data = tags.picture.data;
            const format = tags.picture.format;
            let base64String = "";
            for (let i = 0; i < data.length; i++) {
              base64String += String.fromCharCode(data[i]);
            }
            coverEl.src = `data:${format};base64,${window.btoa(base64String)}`;
            iconEl.classList.add('hidden');
            coverEl.classList.remove('hidden');
          }
        },
        onError: function(error) {
          titleEl.textContent = "Arráncame"; 
          artistEl.innerHTML = '<span class="lang-es">DANIEL, ME ESTÁS MATANDO</span><span class="lang-en hidden">DANIEL, ME ESTÁS MATANDO</span>';
          console.log("No se pudo leer metadata de audio:", error.info);
        }
      });
    }

    playBtn.addEventListener('click', () => {
      if (audio.paused) {
        audio.play().catch(e => console.log("Audio no reproducido"));
      } else {
        audio.pause();
      }
    });

    audio.addEventListener('play', () => {
      iconPlay.classList.add('hidden');
      iconPause.classList.remove('hidden');
      audioWaves.classList.remove('opacity-0');
    });

    audio.addEventListener('pause', () => {
      iconPlay.classList.remove('hidden');
      iconPause.classList.add('hidden');
      audioWaves.classList.add('opacity-0');
    });

    audio.addEventListener('timeupdate', () => {
      if(audio.duration) {
        const percent = (audio.currentTime / audio.duration) * 100;
        progressBar.style.width = percent + '%';
      }
    });

    progressContainer.addEventListener('click', (e) => {
      const rect = progressContainer.getBoundingClientRect();
      const clickX = e.clientX - rect.left;
      const percent = clickX / rect.width;
      audio.currentTime = percent * audio.duration;
    });

    audio.addEventListener('ended', () => {
      iconPlay.classList.remove('hidden');
      iconPause.classList.add('hidden');
      audioWaves.classList.add('opacity-0');
      progressBar.style.width = '0%';
    });
  });
</script>

<style>
  .hover\:shadow-github:hover {
    filter: drop-shadow(0 0 10px rgba(236, 72, 153, 0.6));
  }
  .hover\:shadow-linkedin:hover {
    filter: drop-shadow(0 0 10px rgba(34, 211, 238, 0.6));
  }
  @keyframes musicWave {
    0%, 100% { transform: scaleY(0.5); }
    50% { transform: scaleY(1.5); }
  }
  .animate-musicWave {
    animation: musicWave 1s ease-in-out infinite;
  }
</style>